#!/bin/bash

# Post-commit hook for Tests app
# This script triggers the Tests app to run tests for the current branch
#
# To use this hook:
# 1. Copy or symlink this file to your repository's .git/hooks/post-commit
# 2. Make sure it's executable: chmod +x .git/hooks/post-commit
#
# Example symlink:
# ln -s /path/to/Tests.app/Contents/Resources/post-commit /path/to/repo/.git/hooks/post-commit

# Ignore commits made from linked worktrees.
GIT_DIR="$(git rev-parse --git-dir 2>/dev/null)"
GIT_COMMON_DIR="$(git rev-parse --git-common-dir 2>/dev/null)"

if [ -n "$GIT_DIR" ] && [ -n "$GIT_COMMON_DIR" ]; then
    GIT_DIR_ABS="$(cd "$GIT_DIR" && pwd)"
    GIT_COMMON_DIR_ABS="$(cd "$GIT_COMMON_DIR" && pwd)"

    if [ "$GIT_DIR_ABS" != "$GIT_COMMON_DIR_ABS" ]; then
        exit 0
    fi
fi

# Ignore detached HEAD commits so intermediate scratch commits don't trigger runs.
BRANCH="$(git symbolic-ref --quiet --short HEAD 2>/dev/null)"
if [ -z "$BRANCH" ]; then
    exit 0
fi

# Get the path to TestsCLI
# This script is in the app bundle's Resources folder
# Resolve symlinks to get the actual script location
SCRIPT_PATH="${BASH_SOURCE[0]}"
# If it's a symlink, resolve it
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    # If relative symlink, resolve relative to the directory containing the symlink
    if [[ "$SCRIPT_PATH" != /* ]]; then
        SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$SCRIPT_PATH"
    fi
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
APP_BUNDLE_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
CLI_PATH="$APP_BUNDLE_DIR/Contents/MacOS/TestsCLI"

# Check if TestsCLI exists
if [ ! -f "$CLI_PATH" ]; then
    echo "Error: TestsCLI not found at $CLI_PATH" >&2
    exit 1
fi

# Trigger test run with current branch
"$CLI_PATH" trigger --branch "$BRANCH"

exit 0

